# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# Supabase PostgreSQL — use Session Pooler URL (works on Windows + Render)
# Found in: Supabase dashboard → Settings → Database → Session pooler
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres"
# Local SQLite (optional — for offline dev only)
# DATABASE_URL="file:./dev.db"
# If switching to SQLite: change schema.prisma provider to "sqlite"
# and remove all @db.Decimal / Json field annotations

# ─────────────────────────────────────────────
# JWT Secrets  (generate with: openssl rand -hex 32)
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─────────────────────────────────────────────
# CORS — set to your Cloudflare Pages URL in production
# ─────────────────────────────────────────────
FRONTEND_URL=https://your-app.pages.dev

# ─────────────────────────────────────────────
# OCR — Google Cloud Vision (recommended)
# Free tier: 1,000 requests/month
# Get key: console.cloud.google.com → APIs & Services → Credentials
# Enable: Cloud Vision API, restrict key to Cloud Vision API only
# Set quota cap in Google Cloud Console to avoid unexpected charges
# Falls back to Tesseract.js (local, less accurate) if not set
# ─────────────────────────────────────────────
GOOGLE_CLOUD_VISION_API_KEY=
